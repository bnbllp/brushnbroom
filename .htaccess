RewriteEngine On

# Redirect .html to clean URLs
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internal rewrite to .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# Specific redirects for requested paths if they don't exist
# If /services, /quote, /process, /faq are meant to be sections on the homepage:
RewriteRule ^services$ /#services [R=301,L,NE]
RewriteRule ^quote$ /#quote [R=301,L,NE]
RewriteRule ^process$ /#process [R=301,L,NE]
RewriteRule ^faq$ /#faq [R=301,L,NE]
